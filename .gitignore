# Whitelist-only repo: ignore everything, then un-ignore versioned paths.
# Credentials, certificates, and local env files never enter git.

*

!template.yaml
!README.md
!RELIABILITY.md
!.gitignore
!.samignore
!.env.example

!docs/
!docs/**

!tests/
!tests/**

!lambda_functions/
!lambda_functions/**

!lambda_layers/
!lambda_layers/**

!samconfig accounts/
!samconfig accounts/**

# Local-only (never commit)
.env
.env.*
!.env.example

certificates/
secrets/
generate_token.py
push_*_secrets*.py
push_*_temp.py

*-credentials*.txt
netsuite-oauth-credentials*.txt

*.pem
*.key
*.pfx
*.p12
private_key.pem

.aws-sam/
.venv/
.pytest_cache/
__pycache__/
*.pyc
