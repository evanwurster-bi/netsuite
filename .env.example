# Default local account (duvall | bestimpressions | rockytop)
SANDBOX_ACCOUNT=duvall

# Per-account HubSpot / subsidiary settings live in .env.<account>
# NetSuite OAuth: secrets/netsuite-sandbox.json + certificates/private.pem
# HubSpot token: secrets/hubspot-accounts.json (loaded by local_env.py)
HUBSPOT_DEAL_STAGE_SYNC_ID=

# HubSpot objectTypeId values (portal-specific).
HUBSPOT_OBJECT_TYPE_VENUE=
HUBSPOT_OBJECT_TYPE_PAYMENT=
HUBSPOT_OBJECT_TYPE_LINE_ITEM=

# HubSpot deal property internal name used to resolve the venue name for invoices.
DEAL_VENUE_NAME_PROPERTY=

# Optional webhook objectId allowlist (comma-separated values).
WEBHOOK_OBJECT_ID_FILTER_ENABLED=false
WEBHOOK_OBJECT_ID_FILTER_VALUE=
