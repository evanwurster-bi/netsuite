# Template for local/account-specific environment files.
# Copy to .env or .env.<account> and keep real secrets out of version control.
NETSUITE_ACCOUNT_ID=
NETSUITE_SUBSIDIARY_ID=
NETSUITE_CLIENT_ID=
NETSUITE_CERT_ID=
# Private key PEM using quoted \n escapes, or a single-line base64 PEM (recommended for SAM/Lambda parameters).
NETSUITE_CERT_STRING=

HUBSPOT_API_KEY=
HUBSPOT_DEAL_STAGE_SYNC_ID=

# HubSpot objectTypeId values (portal-specific). Keep these aligned with SAM parameters and Lambda environment variables.
HUBSPOT_OBJECT_TYPE_VENUE=
HUBSPOT_OBJECT_TYPE_PAYMENT=
HUBSPOT_OBJECT_TYPE_LINE_ITEM=

# HubSpot deal property internal name used to resolve the venue name for invoices.
DEAL_VENUE_NAME_PROPERTY=

# Optional webhook objectId allowlist (comma-separated values).
WEBHOOK_OBJECT_ID_FILTER_ENABLED=false
WEBHOOK_OBJECT_ID_FILTER_VALUE=
