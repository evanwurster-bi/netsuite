# Copy to .env and fill in values for local runs (generate_token.py, manual tests).
# Per-account HubSpot / subsidiary settings: copy from .env.duvall, .env.bestimpressions, or .env.rockytop.

NETSUITE_ACCOUNT_ID=
NETSUITE_CLIENT_ID=
NETSUITE_CERT_ID=
NETSUITE_SUBSIDIARY_ID=
HUBSPOT_API_KEY=

# Optional: omit NETSUITE_CERT_STRING to auto-load certificates/private.pem
# NETSUITE_CERT_STRING=

HUBSPOT_DEAL_STAGE_SYNC_ID=
HUBSPOT_OBJECT_TYPE_VENUE=
HUBSPOT_OBJECT_TYPE_PAYMENT=
HUBSPOT_OBJECT_TYPE_LINE_ITEM=
DEAL_VENUE_NAME_PROPERTY=

WEBHOOK_OBJECT_ID_FILTER_ENABLED=false
WEBHOOK_OBJECT_ID_FILTER_VALUE=
